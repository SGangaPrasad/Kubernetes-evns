#!/bin/bash
set -e

# Create the namespace
kubectl create namespace project-h800 --dry-run=client -o yaml | kubectl apply -f -

# Create a StatefulSet to generate the o3db-* pods
kubectl apply -f - <<EOF
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: o3db
  namespace: project-h800
spec:
  serviceName: "o3db-service"
  replicas: 2
  selector:
    matchLabels:
      app: o3db
  template:
    metadata:
      labels:
        app: o3db
    spec:
      containers:
      - name: nginx
        image: nginx:alpine
EOF

echo "✅ Environment setup complete! 2 Pods named o3db-* are spinning up in namespace project-h800."
